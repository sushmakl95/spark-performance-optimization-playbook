# Copy to .env (gitignored) for local dev.

# Java location — Spark 3.5 requires Java 17 (not 21)
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

# Spark warehouse (where managed tables go)
SPARK_WAREHOUSE=/tmp/spark-warehouse

# Dataset root
DATA_DIR=data/generated

# Benchmark defaults
BENCH_SCALE=1x
BENCH_ITERATIONS=3
BENCH_WARMUP=1
